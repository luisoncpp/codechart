{
  "name": "codechart",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "dist:win": "tauri build --bundles nsis,msi",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
