      "id": "app",
      "label": "Application",
      "parentId": null,
      "color": "#64748b",
      "facadeModuleIds": [],
      "annotation": {
        "descriptionShort": "Todo application",
        "descriptionLong": "Top-level container composed from the core, services, and ui groups via group references (not folder ownership), so it claims no leaf module directly — src/main.ts stays ungrouped. Demonstrates membership-by-group-reference and explicit nesting.",
        "icon": "app-window"
      }
    },
    {
      "id": "core",
      "label": "Core",
      "parentId": "app",
      "color": "#7c3aed",
      "facadeModuleIds": ["src/core/index.ts"],
      "annotation": {
        "descriptionShort": "Domain types & state",
        "descriptionLong": "Domain model and in-memory state for todos. Pure logic with no I/O or UI. Code outside this group must go through the facade (index.ts); store, todo, and validate are private.",
        "icon": "cube"
      }
    },
    {
      "id": "services",
      "label": "Services",
      "parentId": "app",
      "color": "#0ea5e9",
      "facadeModuleIds": ["src/services/index.ts"],
      "annotation": {
        "descriptionShort": "Data access",
        "descriptionLong": "Data access layer. Wraps network calls behind http.ts so the rest of the app never calls fetch directly. Exposes fetchTitles through the facade (index.ts).",
        "icon": "plug"
      }
    },
    {
      "id": "shared",
      "label": "Shared",
      "parentId": null,
      "color": "#f59e0b",
      "facadeModuleIds": [],
      "annotation": {
        "descriptionShort": "Cross-cutting types",
        "descriptionLong": "Cross-cutting type modules pulled from multiple folders: services/types.ts via a glob (`match`) and core/todo.ts via an explicit `files` entry. The core and services groups cede these files via `exclude`, so claims stay disjoint (no overlap). Declares no facade, so its members are public to every group (drift detection never flags imports into it).",
        "icon": "share"
      }
    },
    {
      "id": "ui",
      "label": "UI",
      "parentId": "app",
      "color": "#22c55e",
      "facadeModuleIds": ["src/ui/index.ts"],
      "annotation": {
        "descriptionShort": "React components",
        "descriptionLong": "React components that render todos. Depends on core and services through their facades. The TodoList component intentionally bypasses the core facade to demonstrate drift detection.",
        "icon": "layout"
      }
    }
  ],
